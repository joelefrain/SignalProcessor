{
    "units": {
        "time": "s",
        "period": "s",
        "frequency": "Hz",
        "damping_ratio": "decimal",
        "acceleration_internal": "g",
        "velocity_internal": "cm/s",
        "displacement_internal": "cm",
        "acceleration_display": "cm/s^2",
        "input_acceleration_unit": "g",
        "target_spectrum_acceleration_unit": "g"
    },
    "preprocessing": {
        "enabled": false,
        "baseline_correction": {
            "enabled": true,
            "method": "polynomial_or_piecewise_linear",
            "polynomial_order": 1,
            "apply_before_matching": true,
            "apply_after_matching_if_needed": true,
            "acceptance_criterion": {
                "residual_velocity_abs_max_cm_s": 2.0,
                "residual_displacement_abs_max_cm": 5.0
            }
        },
        "filtering": {
            "enabled": true,
            "filter_type": "acausal_butterworth_bandpass",
            "order": 4,
            "low_cut_frequency_hz": 0.05,
            "high_cut_frequency_hz": 50.0,
            "use_record_specific_corner_frequencies": true,
            "avoid_filtering_inside_matching_band": true
        },
        "padding": {
            "enabled": true,
            "pre_event_padding_s": 5.0,
            "post_event_padding_s": 10.0,
            "taper": {
                "enabled": true,
                "type": "cosine",
                "percentage_each_end": 2.0
            }
        }
    },
    "target_spectrum": {
        "damping_ratio": 0.05,
        "interpolation": {
            "method": "log_log",
            "extrapolation": "not_allowed"
        },
        "target_pga": {
            "enabled": true,
            "value": 0.133,
            "unit": "g",
            "use_for_pga_correction": true
        },
        "spectrum_conditioning": {
            "smooth_target_spectrum": false,
            "minimum_period_s": 0.01,
            "maximum_period_s": 2.0
        }
    },
    "matching_period_range": {
        "min_period_s": 0.01,
        "max_period_s": 2.0,
        "period_step_s": 0.02,
        "period_spacing": "linear"
    },
    "linear_scaling": {
        "enabled": true,
        "strategy": "pre_scale_before_spectral_matching",
        "scale_factor": 0.94,
        "allowed_scale_factor_range": {
            "min": 0.25,
            "max": 4.0
        },
        "optimization": {
            "enabled": true,
            "objective": "minimize_log_spectral_misfit",
            "period_range_s": [
                0.01,
                2.0
            ],
            "statistic": "least_squares_log_ratio"
        },
        "preserve_arias_percentage_curve": true
    },
    "elastic_response_spectrum": {
        "enabled": true,
        "oscillator_model": "linear_SDOF",
        "damping_ratio": 0.05,
        "newmark_beta": {
            "gamma": 0.5,
            "beta": 0.25,
            "scheme": "average_acceleration",
            "unconditionally_stable_for_linear_systems": true
        },
        "time_step_control": {
            "maximum_dt_over_T": 0.02,
            "substepping_enabled": true,
            "dt_used": "min(record_dt, maximum_dt_over_T * T)"
        },
        "spectral_quantities": [
            "Sa",
            "Sv",
            "Sd",
            "PSv",
            "PSa"
        ]
    },
    "inelastic_response_spectrum": {
        "enabled": false,
        "oscillator_model": "bilinear_SDOF",
        "ductility_factors_mu": [
            1,
            2,
            3,
            4,
            5,
            6
        ],
        "post_yield_hardening_ratio": 0.02,
        "yield_strength_search": {
            "method": "iterative_strength_reduction",
            "tolerance_mu": 0.01,
            "max_iterations": 100
        },
        "outputs": [
            "inelastic_displacement",
            "yield_strength_coefficient",
            "ductility_demand",
            "hysteretic_energy"
        ]
    },
    "spectral_matching": {
        "enabled": true,
        "algorithm_family": "wavelet_based_time_domain_spectral_matching",
        "preferred_algorithm": "AlAtikAbrahamson_improved_tapered_cosine_wavelet",
        "alternative_algorithm": "Hancock_et_al_wavelet",
        "matching_target": "pseudo_acceleration_response_spectrum",
        "mismatch_tolerance": 0.03,
        "tolerance_type": "fraction_of_target_spectral_ordinate",
        "max_iterations": 500,
        "run_scale_factor": 1.0,
        "convergence": {
            "criterion": "max_abs_relative_spectral_misfit_within_matching_range",
            "max_relative_misfit": 0.03,
            "rms_log_misfit_target": 0.03,
            "stop_if_no_improvement": true,
            "max_consecutive_stagnant_iterations": 10
        },
        "wavelets": {
            "max_number_of_waves": 15,
            "number_additional_waves": 20,
            "placement": "near_time_of_maximum_oscillator_response_for_each_period",
            "amplitude_solution": "least_squares_with_SVD",
            "preserve_nonstationarity": true
        },
        "linear_system_solution": {
            "form": "Delta_R = C * b",
            "unknowns": "wavelet_amplitudes",
            "sensitivity_matrix": "change_in_spectral_response_due_to_unit_wavelet",
            "solver": "SVD_regularized_least_squares",
            "min_eigen_value": 0.0001,
            "off_diagonal_reduction": 0.7,
            "group_size": 250
        },
        "alpha_model": {
            "enabled": true,
            "description": "Controla forma temporal/frecuencia efectiva de wavelets segun periodo/frecuencia.",
            "a1": 1.25,
            "a2": 0.25,
            "f1_hz": 1.0,
            "f2_hz": 4.0
        },
        "pga_correction": {
            "enabled": true,
            "target_pga": 0.133,
            "target_pga_unit": "g",
            "adjustment_frequency_hz": 25.0,
            "damping": 0.1,
            "number_of_cycles": 6,
            "apply_after_spectral_matching": true,
            "avoid_excessive_high_frequency_energy": true
        }
    },
    "arias_intensity_control": {
        "enabled": true,
        "definition": "I_A(t) = pi/(2g) * integral_0^t a(tau)^2 d tau",
        "cumulative_percentage": {
            "enabled": true,
            "definition": "P_A(t) = 100 * I_A(t) / I_A(t_end)",
            "control_points_percent": [
                5,
                10,
                20,
                50,
                75,
                80,
                90,
                95
            ],
            "duration_metrics": [
                "D_5_75",
                "D_5_95",
                "D_20_80"
            ]
        },
        "acceptance_criteria": {
            "arias_total_ratio_min": 0.75,
            "arias_total_ratio_max": 1.35,
            "D_5_95_ratio_min": 0.8,
            "D_5_95_ratio_max": 1.25,
            "D_5_75_ratio_min": 0.8,
            "D_5_75_ratio_max": 1.25,
            "normalized_time_shift_abs_max_for_t5_t50_t95": 0.15,
            "rms_difference_cumulative_arias_fraction_max": 0.1
        },
        "notes": [
            "El escalamiento lineal cambia I_A total por SF^2, pero no cambia P_A(t).",
            "El ajuste espectral por wavelets puede cambiar P_A(t); por ello P_A(t), D_5_95 y D_5_75 se controlan antes y despues del matching."
        ]
    },
    "quality_control": {
        "spectral_fit": {
            "period_range_s": [
                0.01,
                2.0
            ],
            "max_abs_relative_error": 0.03,
            "mean_abs_log_error_max": 0.03,
            "check_periods": "all_matching_periods"
        },
        "time_series_realism": {
            "check_acceleration_time_history": true,
            "check_velocity_time_history": true,
            "check_displacement_time_history": true,
            "check_nonstationary_envelope": true,
            "check_no_late_artificial_pulses": true,
            "check_no_excessive_baseline_drift": true
        },
        "strong_motion_parameters": {
            "compare_before_after": true,
            "parameters": [
                "PGA",
                "PGV",
                "PGD",
                "Arias_intensity",
                "CAV",
                "D_5_75",
                "D_5_95",
                "predominant_period",
                "mean_period",
                "significant_duration"
            ]
        },
        "acceptance_action_if_failed": [
            "reduce_matching_period_range",
            "relax_tolerance",
            "change_seed_record",
            "modify_filter_corners",
            "increase_max_iterations_cautiously",
            "reduce_wavelet_aggressiveness",
            "reject_record"
        ]
    },
    "record_set_requirements": {
        "number_of_records_min": 7,
        "use_suite_mean_spectrum": true,
        "individual_record_matching_allowed": true,
        "suite_statistics": {
            "mean_type": "geometric_mean",
            "dispersion_metric": "log_standard_deviation",
            "check_average_fit": true
        },
        "selection_compatibility": {
            "magnitude_tolerance": 0.5,
            "distance_tolerance_factor": 2.0,
            "site_condition_match": true,
            "fault_mechanism_match": true,
            "pulse_like_records_allowed": "only_if_consistent_with_hazard"
        }
    },
    "outputs": {
        "output_directory": "./examples/output/benchmark",
        "save_scaled_record": true,
        "save_matched_record": true,
        "save_velocity_displacement": true,
        "save_response_spectra": true,
        "save_arias_curves": true,
        "save_quality_report": true,
        "file_naming_template": "{record_id}_SF{scale_factor}_matched",
        "report": {
            "format": [
                "csv",
                "json",
                "md"
            ],
            "include_plots": [
                "acceleration_time_history_before_after",
                "velocity_time_history_before_after",
                "displacement_time_history_before_after",
                "target_vs_initial_vs_matched_spectrum",
                "spectral_misfit_by_period",
                "cumulative_arias_percentage_before_after"
            ]
        }
    },
    "audit_trail": {
        "store_original_record_hash": true,
        "store_config_hash": true,
        "store_software_version": true,
        "store_random_seed": true,
        "random_seed": 12345
    }
}