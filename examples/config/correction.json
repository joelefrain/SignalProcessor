{
    "units": {
        "input_acceleration_unit": "g",
        "working_acceleration_unit": "m/s2",
        "time_unit": "s",
        "velocity_unit": "m/s",
        "displacement_unit": "m"
    },
    "input_record": {
        "event_name": "REEMPLAZAR_EVENTO",
        "component": "H1",
        "dt_s": null,
        "npts": null,
        "start_time_s": 0.0,
        "metadata": {
            "magnitude_mw": null,
            "rupture_distance_km": null,
            "vs30_m_s": null,
            "mechanism": null,
            "source_database": null,
            "is_near_fault": false,
            "possible_permanent_displacement": false
        }
    },
    "pre_checks": {
        "check_missing_values": true,
        "check_gaps": true,
        "check_spikes": true,
        "check_clipping": true,
        "check_unit_consistency": true,
        "max_allowed_gap_samples": 0,
        "spike_detection": {
            "enabled": true,
            "method": "median_absolute_deviation",
            "threshold_mad": 12.0,
            "action": "flag_only"
        },
        "clipping_detection": {
            "enabled": true,
            "flat_top_min_samples": 3,
            "action": "flag_record"
        }
    },
    "windows": {
        "definition_mode": "arias_or_manual",
        "manual_windows_s": {
            "pre_event": [
                0.0,
                null
            ],
            "strong_motion": [
                null,
                null
            ],
            "post_event": [
                null,
                null
            ]
        },
        "arias_detection": {
            "enabled": true,
            "use_for_strong_motion_window": true,
            "lower_fraction": 0.05,
            "upper_fraction": 0.95,
            "pre_event_margin_s": 1.0,
            "post_event_margin_s": 2.0
        },
        "quiet_window_weights": {
            "pre_event_weight": 1.0,
            "strong_motion_weight": 0.0,
            "post_event_weight": 1.0,
            "transition_weight": 0.25
        }
    },
    "baseline_correction": {
        "enabled": true,
        "remove_pre_event_mean_first": true,
        "apply_baseline_to_full_record": true,
        "do_not_correct_pre_and_post_independently": true,
        "time_normalization": {
            "enabled": true
        },
        "candidate_models": [
            {
                "name": "pre_event_mean_only",
                "enabled": true,
                "type": "constant",
                "coefficient_source": "mean_pre_event",
                "apply_to_full_record": true
            },
            {
                "name": "constant_velocity_final",
                "enabled": true,
                "type": "constant",
                "coefficient_source": "constraint_v_final",
                "target_final_velocity_m_s": 0.0,
                "apply_to_full_record": true
            },
            {
                "name": "weighted_polynomial_order_0",
                "enabled": true,
                "type": "weighted_least_squares_polynomial",
                "polynomial_order": 0,
                "fit_windows": [
                    "pre_event",
                    "post_event"
                ],
                "exclude_windows": [
                    "strong_motion"
                ],
                "apply_to_full_record": true
            },
            {
                "name": "weighted_polynomial_order_1",
                "enabled": true,
                "type": "weighted_least_squares_polynomial",
                "polynomial_order": 1,
                "fit_windows": [
                    "pre_event",
                    "post_event"
                ],
                "exclude_windows": [
                    "strong_motion"
                ],
                "apply_to_full_record": true
            },
            {
                "name": "weighted_polynomial_order_2",
                "enabled": true,
                "type": "weighted_least_squares_polynomial",
                "polynomial_order": 2,
                "fit_windows": [
                    "pre_event",
                    "post_event"
                ],
                "exclude_windows": [
                    "strong_motion"
                ],
                "apply_to_full_record": true,
                "requires_justification": true
            },
            {
                "name": "constrained_polynomial_vu_final",
                "enabled": true,
                "type": "constrained_polynomial",
                "polynomial_order": 1,
                "constraints": {
                    "target_final_velocity_m_s": 0.0,
                    "target_final_displacement_m": 0.0,
                    "allow_nonzero_final_displacement_if_near_fault": true
                },
                "solver": "kkt",
                "apply_to_full_record": true
            },
            {
                "name": "velocity_trend_derivative",
                "enabled": true,
                "type": "fit_velocity_trend_then_differentiate",
                "velocity_polynomial_order": 2,
                "fit_windows": [
                    "post_event"
                ],
                "subtract_derivative_from_acceleration": true,
                "apply_to_full_record": true
            },
            {
                "name": "piecewise_offset",
                "enabled": false,
                "type": "piecewise_constant_offset",
                "requires_evidence_of_baseline_shift": true,
                "breakpoints_s": [
                    null,
                    null
                ],
                "constraints": {
                    "target_final_velocity_m_s": 0.0,
                    "target_final_displacement_m": 0.0
                },
                "sensitivity_analysis": {
                    "enabled": true,
                    "breakpoint_variation_s": [
                        -1.0,
                        0.0,
                        1.0
                    ]
                }
            }
        ],
        "model_selection": {
            "strategy": "simplest_model_that_passes_quality_control",
            "maximum_polynomial_order_without_manual_review": 2,
            "reject_if_requires_order_greater_than": 3,
            "score_function": {
                "enabled": true,
                "weights": {
                    "final_velocity_ratio": 1.0,
                    "final_displacement_ratio": 1.0,
                    "post_event_velocity_slope": 1.0,
                    "spectral_change_in_period_range": 1.0,
                    "model_complexity": 0.25,
                    "nonphysical_penalty": 5.0
                }
            }
        }
    },
    "taper_and_padding": {
        "taper": {
            "enabled": true,
            "type": "tukey",
            "taper_fraction_total": 0.05,
            "max_taper_duration_each_end_s": 2.0,
            "do_not_taper_strong_motion_arrival": true
        },
        "padding": {
            "enabled": true,
            "type": "zero_padding",
            "minimum_padding_each_side_s": 5.0,
            "preserve_padding_during_filtering": true,
            "verify_after_trimming": true
        }
    },
    "noise_filtering": {
        "enabled": true,
        "filter_family": "butterworth",
        "phase": "zero_phase_forward_backward",
        "passes": 2,
        "order_per_pass": 4,
        "filter_type": "bandpass",
        "highpass": {
            "enabled": true,
            "selection_method": "snr_plus_displacement_qc",
            "initial_frequency_hz": null,
            "search_grid_hz": {
                "mode": "logspace",
                "min_hz": 0.02,
                "max_hz": 0.5,
                "num": 30
            },
            "snr_threshold": 3.0,
            "use_lowest_frequency_that_passes_qc": true,
            "period_range_constraint": {
                "enabled": true,
                "analysis_tmax_s": null,
                "minimum_cutoff_period_to_tmax_ratio": 1.5
            }
        },
        "lowpass": {
            "enabled": true,
            "selection_method": "snr_nyquist_and_instrument",
            "frequency_hz": null,
            "default_fraction_of_nyquist": 0.75,
            "maximum_frequency_hz": 40.0,
            "snr_threshold": 2.0
        },
        "snr": {
            "enabled": true,
            "noise_window": "pre_event",
            "signal_window": "strong_motion",
            "smoothing": {
                "enabled": true,
                "method": "konno_ohmachi",
                "bandwidth": 40
            }
        }
    },
    "integration": {
        "enabled": true,
        "method": "trapezoidal",
        "initial_velocity_m_s": 0.0,
        "initial_displacement_m": 0.0,
        "integrate_after_baseline_and_filtering": true,
        "compute_velocity": true,
        "compute_displacement": true
    },
    "intensity_measures": {
        "compute": [
            "PGA",
            "PGV",
            "PGD",
            "arias_intensity",
            "husid_curve",
            "significant_duration_5_75",
            "significant_duration_5_95",
            "CAV",
            "fourier_amplitude_spectrum",
            "elastic_response_spectrum"
        ],
        "response_spectrum": {
            "enabled": true,
            "damping_ratio": 0.05,
            "periods_s": {
                "mode": "logspace",
                "min_s": 0.01,
                "max_s": 10.0,
                "num": 200
            },
            "ordinate": "pseudo_acceleration"
        }
    },
    "quality_control": {
        "enabled": true,
        "acceptance_thresholds": {
            "max_abs_final_velocity_m_s": 0.01,
            "max_abs_final_displacement_m": 0.02,
            "max_final_displacement_to_pgd_ratio": 0.1,
            "max_post_event_velocity_slope_m_s2": 0.0005,
            "max_allowed_pga_change_ratio": 0.1,
            "max_allowed_pgv_change_ratio": 0.2,
            "max_allowed_spectral_log_change_in_analysis_range": 0.15,
            "max_allowed_arias_change_ratio": 0.2,
            "max_allowed_duration_5_95_change_ratio": 0.15
        },
        "required_plots": [
            "raw_acceleration",
            "corrected_acceleration",
            "velocity",
            "displacement",
            "fourier_amplitude_spectrum",
            "signal_to_noise_ratio",
            "response_spectrum_before_after",
            "arias_husid_curve"
        ],
        "reject_conditions": [
            "clipping_in_strong_motion",
            "unresolved_gaps",
            "baseline_requires_polynomial_order_greater_than_3",
            "highpass_invalidates_analysis_period_range",
            "large_sensitivity_to_small_highpass_changes",
            "near_fault_pulse_destroyed_by_processing",
            "nonzero_permanent_displacement_forced_to_zero_without_justification"
        ],
        "sensitivity_analysis": {
            "enabled": true,
            "baseline_models_to_compare": [
                "pre_event_mean_only",
                "weighted_polynomial_order_0",
                "weighted_polynomial_order_1",
                "constrained_polynomial_vu_final"
            ],
            "highpass_frequency_multiplier": [
                0.75,
                1.0,
                1.25
            ],
            "filter_order_per_pass": [
                2,
                4
            ],
            "report_variation_in": [
                "PGA",
                "PGV",
                "PGD",
                "arias_intensity",
                "Sa_analysis_range"
            ]
        }
    },
    "outputs": {
        "write_corrected_acceleration": true,
        "write_velocity": true,
        "write_displacement": true,
        "write_response_spectrum": true,
        "write_processing_report": true,
        "output_directory": "./examples/output/correction",
        "file_name_suffix": "_baseline_corrected_filtered",
        "include_config_copy": false
    }
}